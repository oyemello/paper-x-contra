  "metadata": {
    "name": "MyCourses Design System Tokens",
    "description": "Token system for MyCourses redesign - Dieter Rams minimalism + accessibility",
    "version": "1.0.0",
    "author": "Mello",
    "updated": "2026-04-14",
    "baseUnit": "5px",
    "philosophy": "Minimalism (Dieter Rams) + Accessibility (WCAG AA)",
    "notes": {
      "spacing": "5px-based increments (not 8px) for fine-grained control",
      "colors": "Brand red #ED3F1C passes WCAG AA (5.1:1 contrast on white)",
      "typography": "Supports 12px-48px range with proportional line heights",
      "accessibility": "All colors tested for contrast; focus states use 2px stroke"
    }
  }
